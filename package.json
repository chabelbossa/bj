{
  "name": "dossierbj-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @dossierbj/web dev",
    "build": "pnpm --filter @dossierbj/web build",
    "start": "pnpm --filter @dossierbj/web start",
    "lint": "pnpm --filter @dossierbj/web lint",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
